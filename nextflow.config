/*
 * Nextflow Configuration File
 * Author: Dara Mai
 */

// Note: use params.x = 'value' syntax for HPC compatibility (25.x)
// params {} block with types requires Nextflow 26.x+

// Default parameters
params.input = "data/*.fastq.gz"
params.outdir = "results/"


// Profile definitions
profiles {

    // Local execution - for testing without a cluster
    local {
        process.executor = 'local'
        process.cpus = 2
        process.memory = '4.GB'
    }

    // SLURM - for HPC cluster execution 
    slurm {
        process.executor = 'slurm'
        process.queue = 'short'
        process.cpus = 4
        process.memory = '8.GB'
        process.time = '2.h'
    }
}

// Process-specific resource settings
process {

    withName: 'FASTQC' {
        cpus = 2
        memory = '4.GB'
        time = '1.h'
    }
}

// Reporting
report {
    enabled = true
    file = "results/reports/pipeline_report.html"
}

timeline {
    enabled = true
    file = "results/reports/timeline.html"
}